# OSINT-REILLY | Core Infrastructure — Environment Variables
# Path: /home/ubuntu/IT-PROJECTS/00.Wibe-coding_projects/Wibe_Commander/.env
# Line Length Limit: 100 characters

# ── Unified Core LLM Router Keys (Блок №0 та Блок №1) ─────────────────────────────────────────────
# Прямий доступ до моделей від Google (наприклад, швидка базова модель gemini-2.5-flash)
GEMINI_API_KEY=your_gemini_api_key_here

# Надшвидкісний безкоштовний/дешевий доступ до моделей Llama 3.3 через Groq Cloud API
GROQ_API_KEY=your_groq_api_key_here

# Доступ до важких логічних моделей (DeepSeek-R1) через універсальний хаб OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Bright Data Anti-Blocking Infrastructure (Блок №2 та Блок №3) ─────────────────────────────────
# Головний супер-ключ для керування автоматичними скраперами та сесіями
BRIGHTDATA_API_KEY=your_brightdata_api_key_here

# Назва зони резидентських ISP проксі (домашній інтернет для імітації реальних людей)
BRIGHTDATA_ZONE_RESIDENTIAL=your_zone_name

# Назва зони мобільних проксі (найвищий рівень довіри для прориву складних захистів)
BRIGHTDATA_ZONE_MOBILE=your_mobile_zone_name